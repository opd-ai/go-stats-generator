# Cache control headers for GitHub Pages deployment
# Content-hashed WASM binaries can be cached aggressively (immutable)

/wasm/*
  Cache-Control: public, max-age=31536000, immutable

# wasm_exec.js changes with Go versions, cache for 24 hours
/js/wasm_exec.js
  Cache-Control: public, max-age=86400

# HTML pages should be revalidated frequently
/*.html
  Cache-Control: public, max-age=300

# CSS and JS files can be cached for 1 week (update via cache busting if needed)
/css/*
  Cache-Control: public, max-age=604800

/js/*
  Cache-Control: public, max-age=604800
