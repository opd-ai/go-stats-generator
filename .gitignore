# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Build directory
build/
dist/

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# env file
.env

# Editor/IDE
# .idea/
# .vscode/
/go-stats-generator
/go-stats-generator-new
/test-binary
/wasm

# Repository cleanup
# Binary artifacts
*.o
*.bin
*.pyc
*.class
*.wasm

# SQLite database files
*.db
*.db-wal
*.db-shm

# Auto-generated reports and test outputs
*.gen.html
*.gen.md
*.gen.csv

# go-stats-generator analysis outputs
*-baseline.json
*-report.json
*-output.json
*-cleanup.json
*-metrics.json
baseline.json
metrics.json
docs-report.html
cleanup-report.html
pre-*.json
post-*.json

# Additional analysis artifacts
*-fresh.json
*-check.json
*-validation.json
*-circular.json
final.json
corrected.json
diff-report.json
test-full*.json
audit-*.json
